<% papers = @exam&.papers || [] %>

<section class="space-y-8 pb-12">
  <div class="glass-panel rounded-[2rem] px-6 py-8 sm:px-8 md:px-10">
    <%= link_to exams_path, class: "inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-medium text-slate-200 transition hover:bg-white/10 hover:text-white" do %>
      <span aria-hidden="true">←</span>
      Back to exams
    <% end %>

    <div class="mt-8 flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-3xl">
        <span class="soft-label inline-flex rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.28em]">
          Paper archive
        </span>
        <h1 class="mt-4 text-3xl font-semibold tracking-tight text-white sm:text-4xl">
          <%= @exam&.name %> question papers
        </h1>
        <p class="mt-3 text-sm leading-7 text-slate-300 sm:text-base">
          Browse available papers by year and open any PDF in a new tab for quick review.
        </p>
      </div>

      <div class="rounded-3xl border border-white/10 bg-white/5 px-5 py-4">
        <p class="text-xs font-semibold uppercase tracking-[0.28em] text-slate-400">Available papers</p>
        <p class="mt-2 text-3xl font-semibold text-white"><%= papers.size %></p>
      </div>
    </div>
  </div>

  <% if papers.present? %>
    <div class="grid gap-6 xl:grid-cols-2">
      <% papers.group_by(&:year).sort.reverse.each do |year, year_papers| %>
        <section class="glass-panel rounded-[1.75rem] p-6">
          <div class="flex items-center justify-between gap-4 border-b border-white/10 pb-4">
            <h2 class="text-xl font-semibold tracking-tight text-white">
              <%= year || "Unknown year" %>
            </h2>
            <span class="rounded-full bg-amber-300/15 px-3 py-1 text-xs font-semibold uppercase tracking-[0.24em] text-amber-200">
              <%= year_papers.size %> items
            </span>
          </div>

          <ul class="mt-5 space-y-3">
            <% year_papers.each do |paper| %>
              <li class="rounded-2xl border border-white/10 bg-white/5 p-4 transition hover:border-cyan-300/25 hover:bg-white/10">
                <% if paper.pdf_file.attached? %>
                  <%= link_to url_for(paper.pdf_file), target: "_blank", class: "flex items-start justify-between gap-4" do %>
                    <div>
                      <p class="text-base font-semibold text-white"><%= paper.title %></p>
                      <p class="mt-1 text-sm text-slate-400">Open PDF in a new tab</p>
                    </div>
                    <span class="rounded-full border border-cyan-300/20 bg-cyan-300/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-cyan-100">
                      View
                    </span>
                  <% end %>
                <% else %>
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <p class="text-base font-semibold text-slate-200"><%= paper.title %></p>
                      <p class="mt-1 text-sm text-rose-200/80">PDF not available yet</p>
                    </div>
                    <span class="rounded-full border border-rose-300/20 bg-rose-400/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-rose-100">
                      Missing
                    </span>
                  </div>
                <% end %>
              </li>
            <% end %>
          </ul>
        </section>
      <% end %>
    </div>
  <% else %>
    <div class="glass-panel rounded-[1.75rem] px-6 py-12 text-center">
      <p class="text-lg font-semibold text-white">No papers have been uploaded for this exam yet.</p>
      <p class="mt-2 text-sm text-slate-400">Add PDFs in the admin area and they’ll show up here automatically.</p>
    </div>
  <% end %>
</section>
