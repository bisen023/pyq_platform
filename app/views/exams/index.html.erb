<section class="space-y-10 pb-12">
  <div class="glass-panel overflow-hidden rounded-[2rem] px-6 py-8 sm:px-8 md:px-12 md:py-12">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1.2fr)_minmax(280px,0.8fr)] lg:items-end">
      <div class="max-w-3xl">
        <span class="soft-label inline-flex rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.3em]">
          Smart exam prep
        </span>
        <h1 class="section-title mt-5 font-semibold text-white">
          Browse previous year question papers with a cleaner, faster study flow.
        </h1>
        <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-300 sm:text-base">
          Pick an exam, jump into the right year, and open the paper you need without digging through clutter.
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
        <div class="rounded-3xl border border-white/10 bg-white/5 p-5">
          <p class="text-xs font-semibold uppercase tracking-[0.28em] text-slate-400">Total exams</p>
          <p class="mt-3 text-4xl font-semibold text-white"><%= @exams.size %></p>
          <p class="mt-2 text-sm text-slate-400">Organized into a simple card-based library.</p>
        </div>
        <div class="rounded-3xl border border-cyan-300/15 bg-cyan-300/10 p-5">
          <p class="text-xs font-semibold uppercase tracking-[0.28em] text-cyan-100/80">Quick access</p>
          <p class="mt-3 text-base font-semibold text-white">Open papers by exam and year</p>
          <p class="mt-2 text-sm text-cyan-50/75">Less noise, clearer navigation, better focus.</p>
        </div>
      </div>
    </div>
  </div>

  <% if @exams.present? %>
    <div class="grid gap-5 sm:grid-cols-2 xl:grid-cols-3">
      <% @exams.each do |exam| %>
        <%= link_to exam_path(exam), class: "group glass-panel rounded-[1.75rem] p-6 transition duration-300 hover:-translate-y-1.5 hover:border-amber-300/30 hover:shadow-[0_28px_90px_rgba(15,23,42,0.42)]" do %>
          <div class="flex items-start justify-between gap-4">
            <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-amber-300/15 text-sm font-bold uppercase tracking-[0.2em] text-amber-200">
              <%= exam.name.to_s.first(3) %>
            </span>
            <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-slate-300">
              <%= exam.papers.count rescue 0 %> papers
            </span>
          </div>

          <h2 class="mt-8 text-xl font-semibold tracking-tight text-white transition group-hover:text-amber-200">
            <%= exam.name %>
          </h2>

          <p class="mt-3 text-sm leading-6 text-slate-400">
            Explore question papers year by year in a cleaner reading layout.
          </p>

          <div class="mt-8 flex items-center justify-between text-sm font-medium text-slate-300">
            <span>Open archive</span>
            <span class="rounded-full bg-white/5 px-3 py-1 text-amber-200 transition group-hover:bg-amber-300/15">
              View papers
            </span>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="glass-panel rounded-[1.75rem] px-6 py-12 text-center">
      <p class="text-lg font-semibold text-white">No courses or exams are available yet.</p>
      <p class="mt-2 text-sm text-slate-400">Once papers are added, they’ll appear here in this library view.</p>
    </div>
  <% end %>
</section>
